# ----- Server -----
PORT=3000
NODE_ENV=development

# ----- MySQL -----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=github_analyzer
DB_CONNECTION_LIMIT=10

# ----- GitHub API -----
# A personal access token is optional but strongly recommended.
# Without it the GitHub API allows only 60 requests/hour per IP.
# With it you get 5,000 requests/hour. Create one at:
# https://github.com/settings/tokens (no scopes are required for public data).
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
# Max number of repos to scan when computing star/language insights.
GITHUB_MAX_REPOS=300
